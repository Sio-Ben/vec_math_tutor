# 複製為 .env.local 後填入（勿提交 .env.local）
# Supabase：Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://wplxydcjuvghertafknm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 伺服端讀題（可選；若 RLS 擋住 anon 查詢時建議設定）
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# DeepSeek（OpenAI 相容 Chat Completions；僅伺服端；勿提交真金鑰）
# DEEPSEEK_API_KEY=your_deepseek_key_here
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Embedding（RAG 用；預設使用 OpenAI Embeddings）
# OPENAI_API_KEY=your_openai_key_here
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_BASE=https://api.openai.com/v1
# EMBEDDING_BATCH=20
# RAG_TOP_K=3
