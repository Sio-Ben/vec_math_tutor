# 複製為 .env.local 後填入（勿提交 .env.local）
# Supabase：Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://wplxydcjuvghertafknm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# DeepSeek（OpenAI 相容 Chat Completions；僅伺服端；勿提交真金鑰）
# DEEPSEEK_API_KEY=your_deepseek_key_here
# 預設模型為 deepseek-chat；若要改用推理模型可設：
# DEEPSEEK_MODEL=deepseek-reasoner
# 生成/驗題可分模型（未設定時生成沿用 DEEPSEEK_MODEL，驗題預設 deepseek-chat）
# DEEPSEEK_MODEL_GENERATE=deepseek-chat
# DEEPSEEK_MODEL_VALIDATE=deepseek-chat
# 驗題最大迴圈（建議 1~4）
# AI_VALIDATE_MAX_ROUNDS=2
# 開啟 AI prompt/response trace（寫入 .debug/ai-traces/*.jsonl）
# AI_TRACE_LOG=1
